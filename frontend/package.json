{
  "name": "frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "check:architecture": "depcruise src --config .dependency-cruiser.cjs",
    "quality": "npm run lint && npm run check:architecture && npm run test && npm run build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:smoke": "playwright test tests/e2e/smoke",
    "test:e2e:ui": "playwright test --ui",
    "check:bundle-budget": "node scripts/check-bundle-budget.mjs"
  },
  "dependencies": {
    "@ant-design/icons": "^6.3.2",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@tanstack/react-query": "^5.101.2",
    "antd": "^6.5.0",
    "axios": "^1.18.1",
    "dayjs": "^1.11.19",
    "html-to-image": "^1.11.13",
    "i18next": "^26.3.6",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-google-recaptcha-v3": "^1.11.0",
    "react-i18next": "^17.0.10",
    "react-router-dom": "^7.18.1",
    "sonner": "^2.0.7"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@tailwindcss/vite": "^4.3.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "@vitest/coverage-v8": "^4.1.10",
    "dependency-cruiser": "^17.4.3",
    "jsdom": "^29.1.1",
    "oxlint": "^1.71.0",
    "tailwindcss": "^4.3.2",
    "vite": "^8.1.1",
    "vitest": "^4.1.10"
  }
}
