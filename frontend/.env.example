VITE_API_BASE_URL=http://localhost:8000/api
VITE_RECAPTCHA_SITE_KEY=

# Base URL cho asset tĩnh công khai (Cloudflare R2). Để trống -> dùng bucket dev
# mặc định trong src/shared/config/assets.js. Đổi khi tách bucket theo môi trường.
VITE_PUBLIC_ASSET_BASE_URL=
# Cookie consent bật mặc định.
VITE_COOKIE_CONSENT_ENABLED=true

# Cổng subdomain (để trống ở dev — dùng path prefix /tuyendung, /admin)
VITE_MAIN_HOST=
VITE_EMPLOYER_HOST=
VITE_ADMIN_HOST=
# Tuỳ chọn: domain cha dùng cho marker logout giữa các subdomain. Khi bỏ trống,
# frontend tự suy ra từ các host trên (ví dụ `procv.vn`).
VITE_AUTH_SYNC_COOKIE_DOMAIN=
