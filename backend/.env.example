# ─────────────────────────────────────────────────────────────
# Django core
# ─────────────────────────────────────────────────────────────
SECRET_KEY=change-me-to-a-random-secret
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# ─────────────────────────────────────────────────────────────
# Database (PostgreSQL)
# ─────────────────────────────────────────────────────────────
DB_NAME=ai_career_coach
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=localhost
DB_PORT=5432

# ─────────────────────────────────────────────────────────────
# CORS / Frontend
# ─────────────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
# Dùng để dựng link xác thực trong email (trỏ về app frontend)
FRONTEND_URL=http://localhost:5173

# ─────────────────────────────────────────────────────────────
# Media / Upload
# ─────────────────────────────────────────────────────────────
MEDIA_PUBLIC_BASE_URL=
IMAGE_UPLOAD_MAX_SIZE=5242880

# ─────────────────────────────────────────────────────────────
# reCAPTCHA v3
# ─────────────────────────────────────────────────────────────
RECAPTCHA_SECRET_KEY=
RECAPTCHA_SCORE_THRESHOLD=0.5

# ─────────────────────────────────────────────────────────────
# Redis — cache + token xác thực email + cooldown gửi lại
# ─────────────────────────────────────────────────────────────
REDIS_URL=redis://127.0.0.1:6379/1

# ─────────────────────────────────────────────────────────────
# Email (SMTP)
# Để trống EMAIL_HOST_USER -> email in ra console (dev). Điền credential
# là tự gửi thật. Hỗ trợ mọi nhà cung cấp SMTP:
#   • Gmail:      host=smtp.gmail.com  port=587  TLS  (user = email, pass = App Password 16 ký tự,
#                 tạo tại https://myaccount.google.com/apppasswords — cần bật 2FA trước)
#   • SendGrid:   host=smtp.sendgrid.net  port=587  user=apikey  pass=<API_KEY>
#   • Amazon SES: host=email-smtp.<region>.amazonaws.com  port=587  (SMTP credentials)
#   • Mailgun:    host=smtp.mailgun.org  port=587
# ─────────────────────────────────────────────────────────────
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_USE_SSL=False
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_TIMEOUT=10
# Người gửi hiển thị (địa chỉ mặc định = EMAIL_HOST_USER nếu để trống)
EMAIL_FROM_NAME=ProCV
EMAIL_FROM_ADDRESS=
# Ép backend cụ thể nếu muốn (mặc định: có EMAIL_HOST_USER -> smtp, không -> console)
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend

# ─────────────────────────────────────────────────────────────
# Xác thực email
# ─────────────────────────────────────────────────────────────
EMAIL_VERIFICATION_TTL=86400            # hiệu lực link (giây) — mặc định 24h
EMAIL_VERIFICATION_RESEND_COOLDOWN=60   # chờ giữa 2 lần gửi lại (giây)
