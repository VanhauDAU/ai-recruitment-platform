# ─────────────────────────────────────────────────────────────
# Django core
# ─────────────────────────────────────────────────────────────
ENVIRONMENT=development
# Local entry points mặc định dùng config.settings.development. CI dùng
# config.settings.test; production phải đặt config.settings.production.
# Bắt buộc đặt secret ngẫu nhiên riêng cho từng môi trường; không commit giá trị thật.
SECRET_KEY=
JWT_SIGNING_KEY=
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# ─────────────────────────────────────────────────────────────
# Database (PostgreSQL)
# ─────────────────────────────────────────────────────────────
DB_NAME=
DB_USER=
DB_PASSWORD=
DB_HOST=localhost
DB_PORT=5432

# ─────────────────────────────────────────────────────────────
# CORS / Frontend
# ─────────────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
CSRF_TRUSTED_ORIGINS=
# Cookie consent và job-view tracking.
CONSENT_POLICY_VERSION=1
CONSENT_COOKIE_NAME=procv_consent
JOB_VIEW_DEDUP_TTL_SECONDS=86400
JOB_VIEWER_COOKIE_NAME=procv_viewer_id
# Dùng để dựng link xác thực trong email (trỏ về app frontend)
FRONTEND_URL=http://localhost:5173
# Cổng employer có thể ở subdomain riêng ở production; local dùng chung frontend.
EMPLOYER_FRONTEND_URL=http://localhost:5173
EMPLOYER_EMAIL_VERIFICATION_PATH=/tuyendung/app/account/verify
EMPLOYER_PASSWORD_RESET_PATH=/tuyendung/app/reset-password
EMPLOYER_TERMS_POLICY_VERSION=2026-07-18

# Production hardening (bật khi ENVIRONMENT=production).
SECURE_SSL_REDIRECT=False
SECURE_PROXY_SSL_HEADER_ENABLED=False
SESSION_COOKIE_SECURE=False
CSRF_COOKIE_SECURE=False
SECURE_HSTS_SECONDS=0
SECURE_HSTS_INCLUDE_SUBDOMAINS=False
SECURE_HSTS_PRELOAD=False
API_DOCS_ENABLED=True
JWT_ACCESS_TOKEN_MINUTES=15
JWT_REFRESH_TOKEN_DAYS=7
# Admin luôn dùng access token ngắn hơn giá trị chung.
ADMIN_ACCESS_TOKEN_MINUTES=5
# Refresh token chỉ được phát trong cookie HttpOnly, tách theo portal.
# Production bắt buộc Secure=True và SameSite=Lax hoặc Strict.
AUTH_REFRESH_COOKIE_PREFIX=procv_refresh
AUTH_REFRESH_COOKIE_SECURE=False
AUTH_REFRESH_COOKIE_SAMESITE=Lax
AUTH_REFRESH_COOKIE_DOMAIN=
AUTH_REFRESH_COOKIE_PATH=/api/
# Phiên hết hạn khi không hoạt động hoặc vượt quá lifetime của refresh token.
AUTH_SESSION_IDLE_TIMEOUT_SECONDS=1800
AUTH_SESSION_TOUCH_INTERVAL_SECONDS=300
# Cửa sổ cho thao tác cần xác thực lại (OAuth passwordless/giấy phép doanh nghiệp).
AUTH_REAUTH_MAX_AGE_SECONDS=300
# Chỉ các IP/CIDR proxy này mới được phép cung cấp X-Forwarded-For.
TRUSTED_PROXY_IPS=
# Legacy /api/cvs/ and /api/cv-templates/ stay available during the V2
# migration. Values must be ISO-8601 datetimes and are emitted as API headers.
LEGACY_CV_API_DEPRECATION_AT=2026-07-15T00:00:00+00:00
LEGACY_CV_API_SUNSET_AT=2027-01-15T00:00:00+00:00
# Số ngày candidate có thể khôi phục CV đã archive mềm.
CV_ARCHIVE_RESTORE_WINDOW_DAYS=30
# File nguồn import bị xóa bởi Celery beat sau thời gian này; canonical CV vẫn giữ.
CV_IMPORT_SOURCE_RETENTION_DAYS=30

# ─────────────────────────────────────────────────────────────
# Media / Upload
# ─────────────────────────────────────────────────────────────
# URL public của nơi serve /media/ (vd https://static.example.com). Để trống ở local.
MEDIA_PUBLIC_BASE_URL=
IMAGE_UPLOAD_MAX_SIZE=5242880

# Cloudflare R2 — chỉ backend đọc các secret này. KHÔNG đặt chúng trong
# frontend, VITE_*, GitHub Secrets in output, hoặc bất kỳ file commit nào.
# Khi đủ các giá trị bên dưới, media public dùng bucket public; default storage
# dùng bucket private. Không điền access key/secret thật vào file .env.example.
R2_ENDPOINT_URL=
R2_REGION_NAME=auto
# Tạo token tách bucket/quyền. Không dùng chung token public và private.
R2_PUBLIC_ACCESS_KEY_ID=
R2_PUBLIC_SECRET_ACCESS_KEY=
R2_PRIVATE_ACCESS_KEY_ID=
R2_PRIVATE_SECRET_ACCESS_KEY=
R2_PUBLIC_BUCKET=procv-public-media
R2_PRIVATE_BUCKET=procv-private-files
R2_PUBLIC_BASE_URL=

# ─────────────────────────────────────────────────────────────
# reCAPTCHA v3
# ─────────────────────────────────────────────────────────────
RECAPTCHA_SECRET_KEY=
RECAPTCHA_SCORE_THRESHOLD=0.5

# ─────────────────────────────────────────────────────────────
# Redis — cache + token xác thực email + cooldown gửi lại + job-view dedupe
# ─────────────────────────────────────────────────────────────
REDIS_URL=redis://127.0.0.1:6379/1
CELERY_BROKER_URL=redis://127.0.0.1:6379/1
# Để trống nếu không cần query task result.
CELERY_RESULT_BACKEND=

# AI CV import. Admin chọn provider/model; secret chỉ đọc từ environment.
GEMINI_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# ─────────────────────────────────────────────────────────────
# Email (SMTP)
# Để trống EMAIL_HOST_USER -> email in ra console (dev). Điền credential
# là tự gửi thật. Hỗ trợ mọi nhà cung cấp SMTP:
#   • Gmail:      host=smtp.gmail.com  port=587  TLS  (user = email, pass = App Password 16 ký tự,
#                 tạo tại https://myaccount.google.com/apppasswords — cần bật 2FA trước)
#   • SendGrid:   host=smtp.sendgrid.net  port=587  user=apikey  pass=<API_KEY>
#   • Amazon SES: host=email-smtp.<region>.amazonaws.com  port=587  (SMTP credentials)
#   • Mailgun:    host=smtp.mailgun.org  port=587
# ─────────────────────────────────────────────────────────────
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_USE_SSL=False
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_TIMEOUT=10
# Người gửi hiển thị (địa chỉ mặc định = EMAIL_HOST_USER nếu để trống)
EMAIL_FROM_NAME=ProCV
EMAIL_FROM_ADDRESS=
# Ép backend cụ thể nếu muốn (mặc định: có EMAIL_HOST_USER -> smtp, không -> console)
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend

# ─────────────────────────────────────────────────────────────
# Xác thực email
# ─────────────────────────────────────────────────────────────
# decouple KHÔNG cắt comment sau giá trị: viết "86400  # 24h" sẽ ném ValueError
# khi cast=int. Comment phải nằm ở dòng riêng.
# Hiệu lực link (giây) — mặc định 24h
EMAIL_VERIFICATION_TTL=86400
# Chờ giữa 2 lần gửi lại (giây)
EMAIL_VERIFICATION_RESEND_COOLDOWN=60

# ─────────────────────────────────────────────────────────────
# Đặt lại mật khẩu — TTL ngắn hơn xác thực email vì đây là luồng chiếm tài khoản
# ─────────────────────────────────────────────────────────────
# Hiệu lực link (giây) — mặc định 30 phút
PASSWORD_RESET_TTL=1800
# Chờ giữa 2 lần xin link (giây)
PASSWORD_RESET_RESEND_COOLDOWN=60

# ─────────────────────────────────────────────────────────────
# Social login (OAuth) — ứng viên: Google/Facebook/LinkedIn, NTD: chỉ Google.
# Để trống client id/secret -> nút social báo "chưa cấu hình" (không crash).
# Redirect URI đăng ký với provider (backend callback):
#   http://localhost:8000/api/auth/oauth/<provider>/callback/
#   • Google:   https://console.cloud.google.com/apis/credentials
#   • Facebook: https://developers.facebook.com/apps (Facebook Login)
#   • LinkedIn: https://developer.linkedin.com/ (Sign In with LinkedIn - OpenID Connect)
# ─────────────────────────────────────────────────────────────
OAUTH_GOOGLE_CLIENT_ID=
OAUTH_GOOGLE_CLIENT_SECRET=
OAUTH_FACEBOOK_CLIENT_ID=
OAUTH_FACEBOOK_CLIENT_SECRET=
OAUTH_FACEBOOK_GRAPH_VERSION=v21.0
OAUTH_LINKEDIN_CLIENT_ID=
OAUTH_LINKEDIN_CLIENT_SECRET=
# Trang callback frontend (backend redirect về đây kèm one_time_code hoặc error)
OAUTH_MAIN_CALLBACK_URL=http://localhost:5173/oauth/callback
OAUTH_EMPLOYER_CALLBACK_URL=http://localhost:5173/tuyendung/app/oauth/callback
# TTL (giây) cho state OAuth và one_time_code đổi lấy JWT.
OAUTH_STATE_TTL=600
OAUTH_CODE_TTL=120
